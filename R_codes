BestOfSeven <- function(p=.5)
{
###No tie-breaks; just the first to reach 7 points
val = 0
for(j in 0:3) {
	val = val + choose((4+j-1),3)*p^4*(1-p)^j
}
return(val)
}

BestOfK <- function(p=.5,L=3)
{
###No tie-breaks; just the first to reach L+1 points
K=2*L+1
val = 0
for(j in 0:L) {
	val = val + choose(((L+1)+j-1),L)*p^(L+1)*(1-p)^j
}
return(val)
}

