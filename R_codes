Match_Statistics <- function(pA=.5,pB=.5,K0=7,K1=10,Q=2)
{
  thetaS0 = Theta_S(pA,pB,K0)
  thetaS1 = Theta_S(pA,pB,K1)
  outS0 = Set_StatisticsNEW(pA,pB,K0)
  outS1 = Set_StatisticsNEW(pA,pB,K1)
  meanS0 = outS0$meanS
  variS0 = outS0$variS
  meanS1 = outS1$meanS
  variS1 = outS1$variS
  
  LScore = 0:Q
  Awins = rep(0,Q+1)
  Bwins = rep(0,Q+1)
  ABwins = rep(0,Q+1)
  cmean = rep(0,Q+1)
  cvari = rep(0,Q+1)
  
  for(j in 0:Q) {
    Awins[j+1] = JPMFSASB(Q+1,j,pA,pB,K0,K1,Q)
    Bwins[j+1] = JPMFSASB(j,Q+1,pA,pB,K0,K1,Q)
    ABwins[j+1] = Awins[j+1] + Bwins[j+1]
    if(j < Q) {
      cmean[j+1] = (Q+1+j)*meanS0
      cvari[j+1] = (Q+1+j)*variS0}
    else {
      cmean[j+1] = 2*Q*meanS0 + meanS1
      cvari[j+1] = 2*Q*variS0 + variS1
    }
  }
  
  ###match mean and variance
  
  meanM = sum(ABwins*cmean)
  variM = sum(ABwins*cvari) + sum(cmean^2*ABwins) - meanM^2
  stdM = sqrt(variM)
  
  LScore = c(LScore,"Overall")
  Awins_all = sum(Awins)
  Bwins_all = sum(Bwins)
  ABwins_all = sum(ABwins)
  
  Awins = c(Awins,Awins_all)
  Bwins = c(Bwins,Bwins_all)
  ABwins = c(ABwins,ABwins_all)
  cmean = c(cmean,meanM)
  cvari = c(cvari,variM)
  
  table_summary = data.frame(LScore,Awins,Bwins,ABwins,cmean,cvari)
  
  return(list(Awins_all=Awins_all,Bwins_all=Bwins_all,meanM=meanM,variM=variM,stdM=stdM,table_summary=table_summary))
}

