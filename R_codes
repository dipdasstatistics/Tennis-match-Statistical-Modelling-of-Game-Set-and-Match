####Joint PMF of (WA,WB): number of A, B points in set tie-breaker
####
JPMFWAWB <- function(a,b,pA,pB,K)
{
  if((a==K) || (b==K)) {
    val = JPMFWAWB1(a,b,pA,pB,K)
  }
  else {
  qA=1-pA
  qB=1-pB
  numST = numServesST(a+b)
  numA = numST$numAST
  numB = numST$numBST
  
  val = 0
  for(j in 0:a) {
    val=val + choose(numA,j)*choose(numB,a-j)*
      pA^j*qA^(numA-j)*qB^(a-j)*pB^(numB-(a-j))
  }
  }
  return(val)
}

JPMFWAWB1 <- function(a,b,pA,pB,K)
{
  if((a < K) && (b < K)) {
    return("(a<K) and (b<K): Must use JPMWAWB")
  }
  qA=1-pA
  qB=1-pB
  
  whoS = whoServesST(a+b)
  if(a==K) {
    val = JPMFWAWB(K-1,b,pA,pB,K)*pA^whoS*qB^(1-whoS)
  }
  if(b==K) {
    val = JPMFWAWB(a,K-1,pA,pB,K)*qA^whoS*pB^(1-whoS)
  }
  return(val)
}

SetST_Statistics <- function(pA,pB,K) 
{
  qA=1-pA
  qB=1-pB
  
  nval = K + 0:(K-2)
  nval = c(nval,2*(K-1)+ 2/(pA*qB+qA*pB))
  probs = NULL
  for(j in 0:(K-2)) {
    probs = c(probs,JPMFWAWB(K,j,pA,pB,K)+JPMFWAWB(j,K,pA,pB,K))
  }
  probs = c(probs,JPMFWAWB(K-1,K-1,pA,pB,K))
  
  meanST = sum(nval*probs)
  varST = 4*(1-(pA*qB+qA*pB))/((pA*qB+qA*pB)^2)*probs[K]
  varST = varST + (sum(nval^2*probs) - meanST^2)
  stdST = sqrt(varST)
  
  return(list(meanST=meanST,varST=varST,stdST=stdST))
}

####Joint PMF of (GA,GB), the number of games won by (A,B) in a set
####
JPMFGAGB <- function(a,b,pA,pB,K) 
{
  thetaGA = Theta_G(pA)
  thetaGB = Theta_G(pB)
  thetaGAc = 1 - thetaGA
  thetaGBc = 1 - thetaGB
  
  if((a == 6) && (b <= 4)) {
    val = JPMFGAGB(5,b,pA,pB,K)*thetaGA^whoServesS(6+b)*thetaGBc^(1-whoServesS(6+b))
  }
  else if((a <= 4) && (b == 6)) {
    val = JPMFGAGB(a,5,pA,pB,K)*thetaGAc^whoServesS(6+a)*thetaGB^(1-whoServesS(6+a))
  }
  else if((a==6) && (b==6)) {
    val = JPMFGAGB(5,5,pA,pB,K)*(thetaGA*thetaGB + thetaGAc*thetaGBc)
  }
  else if((a==7) && (b==5)) {
    val = JPMFGAGB(5,5,pA,pB,K)*thetaGA*thetaGBc
  }
  else if((a==5) && (b==7)) {
    val = JPMFGAGB(5,5,pA,pB,K)*thetaGAc*thetaGB
  }
  else {
    val = 0
    numS = numServesS(a+b)
    tA = numS$tA
    tB = numS$tB
    
    for(j in 0:a) {
      val = val + choose(tA,j)*choose(tB,a-j)*thetaGA^j*thetaGAc^(tA-j)*
        thetaGBc^(a-j)*thetaGB^(tB-(a-j))
    }
    
  }
  return(val)
}


