}


#####General function for Efficiency Calculation
#####
func_effi <- function(p,al=2,be=1,k1=1,k2=1)
{
  val = (p^(al-1)*(1-p)^(be-1))/(p^k1 + (1-p)^k2)
  return(val)
}

####Integral of func_effi
####
H_Func <- function(low=0,upp=.5,al=2,be=1,k1=1,k2=1)
{
  val = integrate(func_effi,lower=low,upper=upp,al=al,be=be,k1=k1,k2=k2)$value
  return(val)
}

####Delta H
####
Delta_H_Func <- function(al=2,be=1,k1=1,k2=1)
{
  val = H_Func(0,.5,al=al,be=be,k1=k1,k2=k2) - H_Func(.5,1,al=al,be=be,k1=k1,k2=k2)
  return(val)
}

####Efficiency Game under Beta(alpha,beta) prior
####
Effi_Game <- function(al=2,be=1)
{
  eff = 0
  eff = eff + Delta_H_Func(al+1,be,1,1)
  eff = eff - (Delta_H_Func(4+al,0+be,1,1) + 4*Delta_H_Func(4+al,1+be,1,1) + 10*Delta_H_Func(4+al,2+be,1,1))
  eff = eff - 20*Delta_H_Func(5+al,3+be,2,2)
  eff = eff/(Delta_H_Func(1+al,be,1,1) + H_Func(.5,1,al,be,1,1))
  eff = eff*100
  return(eff)
}

####Efficiency (alternative) Game under Beta(alpha,beta) prior
####
Effi2_Game <- function(al=2,be=1)
{
  eff = 0
  eff = eff + Delta_H_Func(al+2,be,2,2)
  eff = eff - (Delta_H_Func(4+al,0+be,1,1) + 4*Delta_H_Func(4+al,1+be,1,1) + 10*Delta_H_Func(4+al,2+be,1,1))
  eff = eff - 20*Delta_H_Func(5+al,3+be,2,2)
  eff = eff/(H_Func(0,.5,2+al,be,2,2) + H_Func(.5,1,al,2+be,2,2))
  eff = eff*100
  return(eff)
}


####Efficiency2 for the Best of K (K is odd)
####
Effi2_Best_of_K <- function(K=7,al=2,be=1)
{
  L = (K-1)/2
  addi = 0
  for(j in 0:L) {
    addi = addi + choose(L+j,L)*Delta_H_Func(L+1+al,j+be,1,1)
  }
  eff = (Delta_H_Func(al+2,be,2,2) - addi)/(H_Func(0,.5,2+al,be,2,2) + H_Func(.5,1,al,2+be,2,2))
  eff = eff*100
  return(eff)
}

