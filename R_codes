####Exact Mean and Variance for Game System
####
Exact_Game <- function(p)
{
  q = 1-p
  mval = 0
  sig2val = 0
  
  for(n in 4:6) {
    mval = mval + n*choose(n-1,3)*(p^4*q^(n-4) + q^4*p^(n-4))
    sig2val = sig2val + n^2*choose(n-1,3)*(p^4*q^(n-4) + q^4*p^(n-4))
  }
  mval = mval + (6+2/(p^2+q^2))*choose(6,3)*p^3*q^3
  sig2val = sig2val + (6+2/(p^2+q^2))^2*choose(6,3)*p^3*q^3 - mval^2 + 4*((1-(p^2+q^2))/(p^2+q^2)^2)*choose(6,3)*p^3*q^3
  sigval = sqrt(sig2val)
  return(list(meangame=mval,varigame=sig2val,stdgame=sigval))
}

####Exact Mean for Set Tie-Breaker System
####
Exact_Set_ST <- function(pA=.5,pB=.5,K=7)
{
	qA=1-pA
	qB=1-pB
	
	meanval = 0
	for(n in K:(2*(K-1))) {
		meanval = meanval + n*(Theta_ST_Exact(n-K,pA,pB,K) + Theta_ST_Exact(n-K,qB,qA,K))
	}
	
	  val3 = 0 ####prob of being tied at (K-1):(K-1)
  
  numS = numServesST(2*K-2)
  sA = numS$numAST
  sB = numS$numBST
    
  for(j in 0:(K-1))
  {
    K1j = K-1-j
    val3 = val3 + choose(sA,j)*choose(sB,K1j)*pA^j*qA^(sA-j)*qB^K1j*pB^(sB-K1j)
  }
	
	meanval = meanval + val3*(2*(K-1) + 2/(pA*qB + qA*pB))
	return(meanval)
}


###Equivalent Form for theta_ST_ExactA
###
Theta_ST_ExactA_Equiv <- function(pA=.5,pB=.5,K=7)
{
	qA = 1-pA
	qB = 1-pB
	
	val = 0
	
	for(l in K:(2*(K-1))) {
		val1=0
		for(j in 0:l) {
		val1 = val1 + choose(K-1,j)*pA^j*qA^(K-1-j)*choose(K-1,l-j)*qB^(l-j)*pB^(K-1-l+j)
		}
		val = val+val1
	}
	
	return(val)
}

Theta_ST_Tie_Equiv <- function(pA=.5,pB=.5,K=7)
{
	qA = 1-pA
	qB = 1-pB
	
	val = 0
	
		for(j in 0:(K-1)) {
		val = val + choose(K-1,j)^2*(pA*pB)^j*(qA*qB)^(K-1-j)
		}
	
	return(val)
}

Theta_ST_Equiv <- function(pA=.5,pB=.5,K=7)
{
	val = Theta_ST_ExactA_Equiv(pA,pB,K)+Theta_ST_Tie_Equiv(pA,pB,K)*Theta_STT(pA,pB)
	return(val)
}


