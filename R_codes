###Game Tie-Break
###Probability of Server winning Tie-Break
Theta_GT <- function(p=.5)
{
  q=1-p
  Odds = p/q
  val = Odds^2/(1+Odds^2)
  return(val)
}

####Game Probability
####Probability that Server wins Game
Theta_G <- function(p=.5)
{
  q = 1-p
  val = p^4 + 4*p^4*q + 10*p^4*q^2 + 20*p^3*q^3*Theta_GT(p)
  return(val)
}

