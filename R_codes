Game_Statistics <- function(p=.5)
{
	q = 1-p
	theta_GA = rep(0,3)
	theta_GB = rep(0,3)
	theta_G = rep(0,3)
	theta_GA_GT = NULL
	theta_GB_GT = NULL
	theta_G_GT = NULL
	mu_G = rep(0,3)
	mu_G_GT = NULL
	sig2_G = rep(0,3)
	sig2_G_GT = NULL
	
	theta_GT = p^2/(p^2+q^2)
	
	ptie = choose(6,3)*p^3*q^3
	
	for(h in 0:2) {
		theta_GA[h+1] = choose(4+h-1,3)*p^4*q^h
		theta_GB[h+1] = choose(4+h-1,3)*q^4*p^h
		theta_G[h+1] = theta_GA[h+1] + theta_GB[h+1]
		mu_G[h+1] = 4+h
		sig2_G[h+1] = 0
	}
	
	theta_GA_GT = ptie*theta_GT
	theta_GB_GT = ptie*(1-theta_GT)
	theta_G_GT = theta_GA_GT + theta_GB_GT
	mu_G_GT = 6 + 2/(p^2+q^2)
	sig2_G_GT = 8*p*q/((p^2+q^2)^2)
	
	
	theta_all_A = 0
	theta_all_B = 0
	theta_all = 0
	mu_all = 0
	sig2_all = 0
	mu2_all = 0
	
	for(h in 0:2) {
		theta_all_A = theta_all_A + theta_GA[h+1]
		theta_all_B = theta_all_B + theta_GB[h+1]
		theta_all = theta_all + theta_G[h+1]
		mu_all = mu_all + theta_G[h+1]*mu_G[h+1]
		sig2_all = sig2_all + theta_G[h+1]*sig2_G[h+1]
		mu2_all = mu2_all + theta_G[h+1]*mu_G[h+1]^2
	}
	
	theta_all_A = theta_all_A + theta_GA_GT
	theta_all_B = theta_all_B + theta_GB_GT
	theta_all = theta_all + theta_G_GT
	mu_all = mu_all + ptie*mu_G_GT
	sig2_all = sig2_all + ptie*sig2_G_GT
	mu2_all = mu2_all + ptie*mu_G_GT^2
	sig2_all = sig2_all + (mu2_all - mu_all^2)
	
	
	Lscore = c(0:2,"GT","Overall")
	Awin = c(theta_GA,theta_GA_GT,theta_all_A)
	Bwin = c(theta_GB,theta_GB_GT,theta_all_B)
	AnyWin = c(theta_G,theta_G_GT,theta_all)
	MeanPts = c(mu_G,mu_G_GT,mu_all)
	Sigma2Pts = c(sig2_G,sig2_G_GT,sig2_all)
	SigmaPts = sqrt(sig2_all)
	
	Table_Summary = data.frame(Lscore,Awin,Bwin,AnyWin,MeanPts,Sigma2Pts)
	
	
	return(list(p=p,Lscore=Lscore,Awin=Awin,Bwin=Bwin,AnyWin=AnyWin,MeanPts=MeanPts,Sigma2Pts=Sigma2Pts,SigmaPts=SigmaPts,Table_Summary=Table_Summary))
}

