###PMF of Sum of Two Binomials
###
PMFTwoBinoms <- function(k,N1,P1,N2,P2)
{
	val = 0
	for(i in 0:N1) {
		val = val + dbinom(i,N1,P1)*dbinom(k-i,N2,P2)
	}
	return(val)
}

CDFTwoBinoms <- function(k,N1,P1,N2,P2)
{
	val = sum(PMFTwoBinoms(0:k,N1,P1,N2,P2))
	return(val)
}

