{
  qA = 1 - pA
  qB = 1 - pB
  
    val2 = 0
    for(j in 0:(K-1))
    {
      numS = numServesST(K+h-1)
      sA = numS$numAST
      sB = numS$numBST
      K1j = K - 1 - j
      val2 = val2 + choose(sA,j)*choose(sB,K1j)*pA^j*qA^(sA-j)*qB^K1j*pB^(sB-K1j)
    }
    Aserving = whoServesST(K+h)
    val2 = val2*pA^Aserving*qB^(1-Aserving)
 
 return(val2)
}

Theta_ST_Tie <- function(n,pA,pB,K) {
	
  qA = 1 - pA
  qB = 1 - pB
  
  val3 = 0
  
  numS = numServesST(2*K-2)
  sA = numS$numAST
  sB = numS$numBST
  Aserving = whoServesST(2*K-1)
  
  for(j in 0:(K-1))
  {
    K1j = K-1-j
    val3 = val3 + choose(sA,j)*choose(sB,K1j)*pA^j*qA^(sA-j)*qB^K1j*pB^(sB-K1j)
  }
  
  L = (n - 2*(K-1))/2
  val3 = val3*(pA*pB + qA*qB)^(L-1)*(pA*qB + qA*pB)
  
  return(val3)
  
}

