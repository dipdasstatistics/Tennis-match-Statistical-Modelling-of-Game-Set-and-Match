####Distribution of Number of Points in a Game
####
ProbNumPointsGame <- function(p=.5,n=4)
{
  q = 1 - p
  prob = 0
  if(n <= 3) 
    {prob = 0}
  else if((n >= 4) && (n <= 6)) 
    {prob = choose(n-1,3)*(p^4*q^(n-4) + q^4*p^(n-4))}
  else if((n > 6) && (n%%2 == 0)) 
  {prob = 20*p^3*q^3*(2*p*q)^((n-6)/2-1)*(p^2+q^2)}
  else {prob = 0}
  return(prob)
}

###Distribution function of Number of Points
###
DistNumPointsGame <- function(p=.5,nseq=1:30)
{
  m = length(nseq)
  probdist = rep(0,m)
  for(l in nseq) {
    probdist[l] = ProbNumPointsGame(p=p,n=l)
  }
  plot(nseq,probdist,type="h",lwd=2,xlab="Number of Points in Game (n)",ylab="Probability",main="PMF of the Number of Points in Game")
  
  meanpts = sum(nseq*probdist)
  varpts = sum(nseq^2*probdist) - meanpts^2
  stdpts = sqrt(varpts)
  
  return(list(dist=data.frame(nseq,probdist),meanpts=meanpts,varpts=varpts,stdpts=stdpts))
}

Prob_NumPointsBofK <- function(p=.5,K=9,n=5)
{
  L = (K-1)/2
  q = 1 - p
  if((n >= (L+1)) && (n <= K)) {
  prob = choose(n-1,L)*(p^(L+1)*q^(n-1-L) + q^(L+1)*p^(n-1-L))
  }
  else {prob = 0}
  return(prob)
}

