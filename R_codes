Set_StatisticsNEW <- function(pA=.5,pB=.5,K=7)
{
  setscores = vector("list",13)
  for(i in 0:4) {setscores[[i+1]] = c(6,i)}
  setscores[[6]] = c(7,5)
  for(i in 0:4) {setscores[[i+7]] = c(i,6)}
  setscores[[12]] = c(5,7)
  setscores[[13]] = c(6,6)

  Ascore = rep(0,13)
  Bscore = rep(0,13)
  probs = rep(0,13)
  cmean = rep(0,13)
  cvari = rep(0,13)
  
  i = 0
  for(sc in setscores) {
    i = i+1
    Ascore[i] = sc[1]
    Bscore[i] = sc[2]
    probs[i] = JPMFGAGB(sc[1],sc[2],pA,pB,K)
    
    out=Set_Mean_Vari(sc[1],sc[2],pA,pB)
    cmean[i] = out$meanS
    cvari[i] = out$sig2S
    
  }
  
  ###Adjust for the STT
  outST = SetST_Statistics(pA,pB,K)
  meanST = outST$meanST
  variST = outST$varST
  
  cmean[13] = cmean[13] + meanST
  cvari[13] = cvari[13] + variST
  
  ####computing mean and variance
  ####note: this is via iterated rule
  
  AProbWin = 0
  BProbWin = 0
  
  for(j in 1:6) {
    AProbWin = AProbWin + probs[j]
    BProbWin = BProbWin + probs[6+j]
  }
  AProbWin = AProbWin + probs[13]*Theta_ST(pA,pB,K)
  BProbWin = BProbWin + probs[13]*(1-Theta_ST(pA,pB,K))
  meanS = 0
  variS = 0
  
  for(i in 1:13) {
    meanS = meanS + probs[i]*cmean[i]
    variS = variS + (cmean[i]^2 + cvari[i])*probs[i] 
  }
  variS = variS - meanS^2
  stdS = sqrt(variS)
  
  LScore=c(0:6,"Overall")
  Awins = c(probs[1:6],probs[13]*Theta_ST(pA,pB,K))
  Awins = c(Awins,AProbWin)
  Bwins = c(probs[7:12],probs[13]*(1-Theta_ST(pA,pB,K)))
  Bwins = c(Bwins,BProbWin)
  ABwins = Awins+Bwins
  ABwins = ABwins
  cmeancom = c(cmean[1:6],cmean[13])
  cmeancom = c(cmeancom,meanS)
  cvarcom = c(cvari[1:6],cvari[13])
  cvarcom = c(cvarcom,variS)
  tabsummary2 = data.frame(LScore=LScore,round(data.frame(Awins=Awins,Bwins=Bwins,ABwins=ABwins,cmeancom=cmeancom,cvarcom=cvarcom),3))
  
  return(list(AProbWin=AProbWin,BProbWin=BProbWin,meanS=meanS,variS=variS,stdS=stdS,tabsummary= round(data.frame(Ascore,Bscore,probs,cmean,cvari),3),tabsummary2=tabsummary2))
}

