####JPMF of (SA,SB) for a Best-of-L = (2Q + 1) match
####
JPMFSASB <- function(a,b,pA=.5,pB=.5,K0=7,K1=10,Q=2)
{
  thetaS0 = Theta_S(pA,pB,K0)
  thetaS1 = Theta_S(pA,pB,K1)
  
  if((a > Q+1) || (b > Q+1)) {
    return("a or b exceeded Q+1")
  }
  
  if((a == (Q+1)) && (b < Q)) {
    val = JPMFSASB(Q,b,pA,pB,K0,K1,Q)*thetaS0
  }
  else if((a == (Q+1)) && (b == Q)) {
    val = JPMFSASB(Q,Q,pA,pB,K0,K1,Q)*thetaS1
  }
  else if((a < Q) && (b == (Q+1))) {
    val = JPMFSASB(a,Q,pA,pB,K0,K1,Q)*(1-thetaS0)
  }
  else if((a==Q) && (b == (Q+1))) {
    val = JPMFSASB(Q,Q,pA,pB,K0,K1,Q)*(1-thetaS1)
  }
  else {
    val = choose(a+b,a)*thetaS0^a*(1-thetaS0)^b
  }

return(val)
}

