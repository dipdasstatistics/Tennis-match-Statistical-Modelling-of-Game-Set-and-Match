####Set Tie-Breaker's Tie-Breakers
####Probability that Server wins this Tie-Breaker's Tie-Breaker
Theta_STT <- function(pA=.5,pB=.5)
{
	qA = 1 - pA
	qB = 1 - pB
	
 # OddsA = pA/(1-pA)
 # OddsB = pB/(1-pB)
 # OR = OddsA/OddsB
 # val = OR/(1+OR)
 
 if((pA==0) && (pB==0)) {val = 1/2}
 else if((pA==1) && (pB==1)) {val = 1/2}
 else if((pA==0) && (pB > 0)) {val = 0}
 else if((pA>0) && (pB==0)) {val = 1}
 else if((pA==1) && (pB < 1)) {val = 1}
 else if((pA<1) && (pB==1)) {val = 0}
 else {val = pA*qB/(qA*pB+pA*qB)}
 
  return(val)
}

####Determining Number of Serves in set tie-breaker
####
numServesST <- function(n=10)
{
  numA = 0
  for(j in 1:n) {
    numA = numA + ((j%%4) <= 1)
  }
  numB = n - numA
  return(list(numAST=numA,numBST=numB))
}

####Determining who is serving (1 if A, 0 if B) in set tie-breaker
####
whoServesST <- function(n=10)
{
  val = ((n%%4) <= 1)
  return(as.numeric(val))
}

####Set Tie-Breaker Probability
####Probability that Server wins set tie-breaker with K points
####
Theta_ST <- function(pA=.5,pB=.5,K=7)
{
  qA = 1 - pA
  qB = 1 - pB
  
  val1 = 0
  
  for(h in 0:(K-2))
  {
    val2 = 0
    for(j in 0:(K-1))
    {
      numS = numServesST(K+h-1)
      sA = numS$numAST
      sB = numS$numBST
      K1j = K - 1 - j
      
      if((j <= sA) && (K1j <= sB)) {
      val2 = val2 + choose(sA,j)*choose(sB,K1j)*pA^j*qA^(sA-j)*qB^K1j*pB^(sB-K1j)
      }
      
    }
    Aserving = whoServesST(K+h)
    val1 = val1 + val2*pA^Aserving*qB^(1-Aserving)
  }
  
  val3 = 0
  
  numS = numServesST(2*K-2)
  sA = numS$numAST
  sB = numS$numBST
  Aserving = whoServesST(2*K-1)
  
  for(j in 0:(K-1))
  {
    K1j = K-1-j
   if((j <= sA) && (K1j <= sB)) {
    val3 = val3 + choose(sA,j)*choose(sB,K1j)*pA^j*qA^(sA-j)*qB^K1j*pB^(sB-K1j)
    }
  }
  
  sttprob = Theta_STT(pA,pB)
  val1 = val1 + val3*sttprob^Aserving*(1-sttprob)^(1-Aserving)
  
  return(val1)
  
}


