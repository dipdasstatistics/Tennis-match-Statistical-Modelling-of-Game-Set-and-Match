####Mean and Variance for BOK Systems
####
Mean_Vari_BOKG <- function(pA=.5,pB=.5,L=10)
{
	avec = c(rep(L+1,L),0:(L-1),L)
	bvec = c(0:(L-1),rep(L+1,L),L)
	len = length(avec)
	probvec = rep(0,len)
	cmeanvec = rep(0,len)
	cvarivec = rep(0,len)
	
	thetaGA = Theta_G(pA)
	thetaGB = Theta_G(pB)
	
	out_GameA = Mean_Vari_Game(pA)
	GameA_mean = out_GameA$mean_Game
	GameA_vari = out_GameA$vari_Game
	out_GameB = Mean_Vari_Game(pB)
	GameB_mean = out_GameB$mean_Game
	GameB_vari = out_GameB$vari_Game
		
	for(i in 1:len)
	{
		probvec[i] = JPMF_GAGB_BOKG(avec[i],bvec[i],pA,pB,L)
		numS = numServesS(avec[i]+bvec[i])
		cmeanvec[i] = numS$tA*GameA_mean + numS$tB*GameB_mean
		cvarivec[i] = numS$tA*GameA_vari + numS$tB*GameB_vari		
	}
	

	
	###Adjust values when tied under the three systems
	###System1 (SD)
	cmeanvec1 = cmeanvec
	cmeanvec1[2*L+1] = cmeanvec1[2*+1] + .5*(GameA_mean + GameB_mean)
	cvarivec1 = cvarivec
	cvarivec1[2*L+1] = cvarivec1[2*+1] + .5*(GameA_vari + GameB_vari)
	
	####System2 (STTG)
	out2_NSTT = Mean_Vari_NSTT(thetaGA,thetaGB)
	cmeanvec2 = cmeanvec
	cmeanvec2[2*L+1] = cmeanvec2[2*+1] + out2_NSTT$mean_NSTT
	cvarivec2 = cvarivec
	cvarivec2[2*L+1] = cvarivec2[2*+1] + out2_NSTT$vari_NSTT
	
	####System3 (STTP)
	out3_NSTT = Mean_Vari_NSTT(pA,pB)
	cmeanvec3 = cmeanvec
	cmeanvec3[2*L+1] = cmeanvec3[2*+1] + out3_NSTT$mean_NSTT
	cvarivec3 = cvarivec
	cvarivec3[2*L+1] = cvarivec3[2*+1] + out3_NSTT$vari_NSTT
	
	####Overall Probabilities of A winning
	BOKG_Probs = Theta_BOKG(pA,pB,L)

####Unconditional Mean and Variance and Std Deviation
	BOKG1 = Iter_Mean_Vari(probvec,cmeanvec1,cvarivec1)
	BOKG2 = Iter_Mean_Vari(probvec,cmeanvec2,cvarivec2)
	BOKG3 = Iter_Mean_Vari(probvec,cmeanvec3,cvarivec3)

return(list(pA=pA,pB=pB,L=L,avec=avec,bvec,probvec=probvec,BOKG_Probs=BOKG_Probs,BOKG1=BOKG1,BOKG2=BOKG2,BOKG3=BOKG3))

}

####Iterated Rules for Mean and Variance given conditional mean and variance
####
Iter_Mean_Vari <- function(probs,cmean,cvari)
{
	umean = sum(probs*cmean)
	uvari = sum(probs*cvari) + sum(probs*cmean^2) - umean^2
	ustd = sqrt(uvari)
	return(list(umean=umean,uvari=uvari,ustd=ustd))
}


####Create Comparative Table Between Match System and BOKG2 System
####
Compare_Match_BOKG <- function(pA=.5,pB=.5,L=10,K0=7,K1=10,Q=2)
{
  out_BOKG = Mean_Vari_BOKG(pA=pA,pB=pB,L=L)
  summ_BOKG = round(c(out_BOKG$BOKG_Probs$theta_GOBK2,unlist(out_BOKG$BOKG2)),4)
  names(summ_BOKG) = c("Prob A wins","MeanPts","VarPts","StdPts")
  
  out_Match = Match_Statistics(pA=pA,pB=pB,K0=K0,K1=K1,Q=Q)
  summ_Match = round(c(out_Match$Awins_all,out_Match$meanM,out_Match$variM,out_Match$stdM),4)
  names(summ_Match) = c("Prob A wins","MeanPts","VarPts","StdPts")
  
  Diff_Probs = summ_Match[1]-summ_BOKG[1]
  Ratio_Probs = summ_Match[1]/summ_BOKG[1]
  Ratio_Means = summ_Match[2]/summ_BOKG[2]
  Ratio_Stds = summ_Match[4]/summ_BOKG[4]
  
  return(list(summ_Match=summ_Match,summ_BOKG=summ_BOKG,Diff_Probs=Diff_Probs,Ratio_Probs=Ratio_Probs,Ratio_Means=Ratio_Means,Ratio_Stds=Ratio_Stds))
}

Contour_Compare_Match_BOKG <- function(pAvec=seq(.01,.99,.01),pBvec=seq(.01,.99,.01),L=10,K0=7,K1=10,Q=2,nlevs=30)
{
  len = length(pAvec)
  Diff_Probs_mat = matrix(0,len,len)
  Ratio_Probs_mat = matrix(0,len,len)
  Ratio_Means_mat = matrix(0,len,len)
  Ratio_Stds_mat = matrix(0,len,len)
  
  for(i in 1:len) {
    pA = pAvec[i]
    for(j in 1:len) {
      pB = pBvec[j]
      out = Compare_Match_BOKG(pA,pB,L,K0,K1,Q)
      Diff_Probs_mat[i,j] = out$Diff_Probs
      Ratio_Probs_mat[i,j] = out$Ratio_Probs
      Ratio_Means_mat[i,j] = out$Ratio_Means
      Ratio_Stds_mat[i,j] = out$Ratio_Stds
    }}
  
  close.screen(all.screens=T)
  split.screen(c(2,2))
  screen(1)
  contour(pAvec,pBvec,Diff_Probs_mat,main="Diff Probs",nlevels=nlevs)
  #scan()
  screen(2)
  contour(pAvec,pBvec,Ratio_Probs_mat,main="Ratio Probs",nlevels=nlevs)
  #scan()
  screen(3)
  contour(pAvec,pBvec,Ratio_Means_mat,main="Ratio Means",nlevels=nlevs)
  #scan()
  screen(4)
  contour(pAvec,pBvec,Ratio_Stds_mat,main="Ratio Stds",nlevels=nlevs)
  
  return(list(L=L,pAvec=pAvec,pBvec=pBvec,Diff_Probs_mat=Diff_Probs_mat,Ratio_Probs_mat=Ratio_Probs_mat,Ratio_Means_mat=Ratio_Means_mat,Ratio_Stds_mat=Ratio_Stds_mat))
}

