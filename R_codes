DistNumPointsST <- function(n,pA=.5,pB=.5,K=7)
{
  qA = 1 - pA
  qB = 1 - pB
  prob = 0
  
  if((n >= K) && (n <= 2*(K-1))) {
  	prob = Theta_ST_Exact(n-K,pA,pB,K) + Theta_ST_Exact(n-K,qA,qB,K)
  }
  
  if((n >= 2*K) && (n%%2 == 0)) {
  	prob = Theta_ST_Tie(n,pA,pB,K)
  }
  
  return(prob)
}

