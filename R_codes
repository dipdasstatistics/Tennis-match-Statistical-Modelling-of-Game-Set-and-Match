#####Best_of-(2L+1)-Games System (BOKG)
#####
JPMF_GAGB_BOKG <- function(a,b,pA,pB,L)
{
	thetaGA = Theta_G(pA)
	thetaGB = Theta_G(pB)
	
	if((a == (L+1)) && (b < L)) {
		numS = numServesS(L+b)
		tA = numS$tA
		tB = numS$tB
		whoS = whoServesS(L+1+b)
		val = PMFTwoBinoms(L,tA,thetaGA,tB,1-thetaGB)
		val = val*thetaGA^whoS*(1-thetaGB)^(1-whoS)
	}
	else if((a < L) && (b == (L+1))) {
		numS = numServesS(L+a)
		tA = numS$tA
		tB = numS$tB
		whoS = whoServesS(L+1+a)
		val = PMFTwoBinoms(L,tA,1-thetaGA,tB,thetaGB)
		val = val*(1-thetaGA)^whoS*thetaGB^(1-whoS)
	}
	else {
		numS = numServesS(a+b)
		tA = numS$tA
		tB = numS$tB
		val = PMFTwoBinoms(L,tA,thetaGA,tB,1-thetaGB)
	}
	
	return(val)
}

Theta_BOKG <- function(pA,pB,L)
{
	thetaGA = Theta_G(pA)
	thetaGB = Theta_G(pB)

	val = 0
	for(b in 0:(L-1)) {
		val = val + JPMF_GAGB_BOKG(L+1,b,pA,pB,L)
	}
	
	tieprob = JPMF_GAGB_BOKG(L,L,pA,pB,L)
	
	val1 = val + tieprob*.5*(thetaGA + (1-thetaGB))
	val2 = val + tieprob*Theta_STT(thetaGA,thetaGB)
	val3 = val + tieprob*Theta_STT(pA,pB)

	return(list(pA=pA,pB=pB,L=L,theta_GOBK1=val1,theta_GOBK2=val2,theta_GOBK3=val3))
	
	return(val)
}

###mean and Variance of NSTT under (pA,pB)
###
Mean_Vari_NSTT <- function(pA,pB)
{
	qA=1-pA
	qB=1-pB
	succprob = pA*qB +qA*pB
	mean_NSTT = 2/(succprob)
	vari_NSTT = 4*(1-succprob)/succprob^2
	return(list(mean_NSTT=mean_NSTT,vari_NSTT=vari_NSTT))
}


