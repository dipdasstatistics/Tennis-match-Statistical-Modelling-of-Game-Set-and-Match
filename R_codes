####Set Probability
####
Theta_S <- function(pA=.5,pB=.5,K=7)
{
  gameA = Theta_G(pA)
  gameB = Theta_G(pB)
  
  val1 = 0
  
  for(h in 0:4) {
    
    val2 = 0
    JA = whoServesS(6+h)
    numS = numServesS(6+h-1)
    tA = numS$tA
    tB = numS$tB
    
    for(j in 0:5) {
    	if((j <= tA) && ((5-j) <= tB)) {
      val2 = val2 + choose(tA,j)*choose(tB,5-j)*gameA^j*(1-gameA)^(tA-j)*(1-gameB)^(5-j)*gameB^(tB-(5-j))
      }
    }
    
    val2 = val2*gameA^JA*(1-gameB)^(1-JA)
    
    val1 = val1 + val2
  }
  
  p55 = 0
  for(j in 0:5) {
    p55 = p55 + (choose(5,j))^2 * (gameA*gameB)^j*((1-gameA)*(1-gameB))^(5-j)
  }
  
  val1 = val1 + p55*gameA*(1-gameB) + p55*(gameA*gameB + (1-gameA)*(1-gameB))*Theta_ST(pA,pB,K)
  
  return(val1)
}

